{{> menu id="dashboard"}}

{{> listplaylists}}
{{> addplaylist}}
<form class="ui form" action="/dashboard/addplaylist" method="POST">

  <div class="two fields">

    <div class="field">
      <label>Title</label>
      <input placeholder="Title" type="text" name="title" required>
    </div>

    <div class="field">
      <label>Rating</label>
      <input type="range" name="rating" min="1" max="5" value="3">
    </div>

  </div>

  <button class="ui blue button">Add Playlist</button>

</form>