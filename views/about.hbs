{{> menu id="about"}}

<section class="ui left aligned middle aligned segment">
  <h2>About the Playlist app</h2>
  <h3>Our Team</h3>

  <div class="ui three stackable cards">

    {{#each employees}}
      <div class="ui card">
        <div class="image">
          <img src="{{image}}">
        </div>
        <div class="content">
          <a class="header">{{fullname}}</a>
          <div class="meta">
            <span class="date">Joined in {{joined}}</span>
          </div>
          <div class="description">
            {{name}} is an {{job}} living in {{city}}.
          </div>
        </div>
        <div class="extra content">
          <i class="user icon"></i>
          {{mates}} contacts
        </div>
      </div>
    {{/each}}

  </div>
</section>